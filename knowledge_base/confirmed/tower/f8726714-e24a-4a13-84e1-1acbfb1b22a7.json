  "judge_dna": "agent_id='judge' model_name='minimax-m2.5:cloud' model_family='minimax' training_origin='minimax' cultural_lens='european_regulatory' known_blind_spots=['cloud-dependent latency'] lora_adapter_path=None generation=0",
